<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, viewport-fit=cover"
  />
  <title>Angel's Arcade — Checkers</title>
  <style>
    :root {
      --bg-0: #08120f;
      --bg-1: #0c1a16;
      --panel: rgba(10, 24, 21, 0.88);
      --panel-2: rgba(13, 29, 25, 0.94);
      --frame-1: #21463d;
      --frame-2: #17352e;
      --frame-3: #0c211c;
      --emerald-dark: #14352e;
      --emerald-dark-2: #102b25;
      --opal-light: #e7e3ef;
      --opal-light-2: #d7d1e7;
      --opal-shadow: #bbb4cd;
      --text-main: #f3f1f8;
      --text-soft: #cfd5d2;
      --text-dim: #9aa8a3;
      --accent: #6ed0a9;
      --accent-2: #a68cff;
      --danger: #f6aeb6;
      --gold: #ddc57a;
      --border: rgba(255, 255, 255, 0.08);
      --shadow-lg:
        0 22px 50px rgba(0, 0, 0, 0.42),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
      --shadow-md:
        0 12px 28px rgba(0, 0, 0, 0.34),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
      --tile-size: min(10vw, 70px);
      --board-size: min(80vw, 560px);
      --radius-panel: 18px;
      --radius-button: 14px;
      --font-ui: "Georgia", "Times New Roman", serif;
      --font-body: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top, rgba(130, 220, 178, 0.09), transparent 26%),
        radial-gradient(circle at bottom right, rgba(180, 150, 255, 0.08), transparent 24%),
        linear-gradient(180deg, #0a1714 0%, #08110e 100%);
      color: var(--text-main);
      font-family: var(--font-body);
    }

    body {
      padding: 24px;
    }

    .page-shell {
      max-width: 1320px;
      margin: 0 auto;
    }

    .title-wrap {
      margin-bottom: 18px;
      text-align: center;
    }

    .title-wrap h1 {
      margin: 0;
      font-family: var(--font-ui);
      font-size: clamp(2rem, 3vw, 3rem);
      font-weight: 700;
      letter-spacing: 0.03em;
      text-shadow: 0 1px 0 rgba(255,255,255,0.08), 0 10px 26px rgba(0,0,0,0.35);
    }

    .title-wrap p {
      margin: 8px 0 0;
      color: var(--text-soft);
      font-size: 0.98rem;
      letter-spacing: 0.02em;
    }

    .game-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 22px;
      align-items: start;
    }

    .board-column,
    .sidebar {
      min-width: 0;
    }

    .board-card,
    .panel {
      position: relative;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.015)),
        linear-gradient(180deg, var(--panel), var(--panel-2));
      border: 1px solid var(--border);
      border-radius: var(--radius-panel);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      backdrop-filter: blur(8px);
    }

    .board-card {
      padding: 20px;
    }

    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .panel {
      padding: 16px;
    }

    .panel h2 {
      margin: 0 0 14px;
      font-family: var(--font-ui);
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      font-weight: 700;
      color: var(--text-main);
    }

    .board-frame {
      width: min(100%, 620px);
      margin: 0 auto;
      padding: 18px;
      background:
        linear-gradient(145deg, #316659 0%, #21493f 26%, #19382f 52%, #285448 78%, #143028 100%);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0;
      box-shadow:
        inset 0 2px 8px rgba(255,255,255,0.08),
        inset 0 -4px 14px rgba(0,0,0,0.35),
        0 18px 34px rgba(0,0,0,0.34);
    }

    .board-inner {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: #0d201b;
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow:
        inset 0 2px 0 rgba(255,255,255,0.08),
        inset 0 -4px 14px rgba(0,0,0,0.25);
      position: relative;
      overflow: hidden;
    }

    .board-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: repeat(8, 1fr);
      width: 100%;
      height: 100%;
    }

    .square {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }

    .square.light {
      background:
        linear-gradient(145deg, #f4f1fb 0%, #e2ddf0 56%, #cdc7df 100%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.55),
        inset 0 -1px 0 rgba(140,128,165,0.15);
    }

    .square.dark {
      background:
        linear-gradient(145deg, #1a463d 0%, #163c34 45%, #12312a 100%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.06),
        inset 0 -1px 0 rgba(0,0,0,0.18);
    }

    .square.selected::after,
    .square.legal::after,
    .square.capture-target::after,
    .square.must-piece::before,
    .square.last-move::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .square.selected::after {
      box-shadow: inset 0 0 0 4px rgba(166, 140, 255, 0.88);
    }

    .square.legal::after {
      inset: 28%;
      border-radius: 999px;
      background: rgba(110, 208, 169, 0.28);
      box-shadow: 0 0 0 2px rgba(110, 208, 169, 0.24);
    }

    .square.capture-target::after {
      box-shadow: inset 0 0 0 4px rgba(221, 197, 122, 0.92);
    }

    .square.must-piece::before {
      box-shadow: inset 0 0 0 3px rgba(246, 174, 182, 0.9);
    }

    .square.last-move::before {
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0));
    }

    .coords {
      position: absolute;
      inset: 0;
      pointer-events: none;
      font-family: var(--font-body);
      font-size: 0.7rem;
      color: rgba(255,255,255,0.52);
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .coord-file,
    .coord-rank {
      position: absolute;
      line-height: 1;
    }

    .coord-file {
      bottom: 4px;
      right: 5px;
    }

    .coord-rank {
      top: 5px;
      left: 5px;
    }

    .piece {
      width: 78%;
      height: 78%;
      display: block;
      cursor: pointer;
      filter: drop-shadow(0 4px 7px rgba(0,0,0,0.35));
      transform: translateZ(0);
    }

    .piece-svg {
      width: 100%;
      height: 100%;
      display: block;
      pointer-events: none;
    }

    .controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .btn {
      appearance: none;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius-button);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02)),
        linear-gradient(180deg, #19362f, #102520);
      color: var(--text-main);
      padding: 11px 14px;
      font: inherit;
      font-weight: 700;
      letter-spacing: 0.02em;
      cursor: pointer;
      box-shadow: var(--shadow-md);
      transition: transform 120ms ease, border-color 120ms ease, background 120ms ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      border-color: rgba(110, 208, 169, 0.42);
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn.full {
      grid-column: 1 / -1;
    }

    .status-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .status-row {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 12px;
      align-items: start;
      padding: 10px 12px;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      background: rgba(255,255,255,0.02);
    }

    .status-label {
      color: var(--text-dim);
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .status-value {
      color: var(--text-main);
      font-weight: 600;
      line-height: 1.35;
      word-break: break-word;
    }

    .capture-wrap {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .capture-box {
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.015));
      padding: 12px;
      min-height: 84px;
    }

    .capture-box h3 {
      margin: 0 0 10px;
      font-size: 0.9rem;
      color: var(--text-soft);
      letter-spacing: 0.03em;
      font-weight: 700;
    }

    .capture-pieces {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .capture-piece {
      width: 32px;
      height: 32px;
      flex: 0 0 auto;
      opacity: 0.95;
    }

    .moves-table-wrap {
      max-height: 300px;
      overflow: auto;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.06);
      background: rgba(255,255,255,0.02);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: rgba(10, 24, 21, 0.96);
      color: var(--text-soft);
      text-align: left;
      font-family: var(--font-ui);
      letter-spacing: 0.03em;
      padding: 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    tbody td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: top;
      color: var(--text-main);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    .note {
      margin-top: 12px;
      color: var(--text-dim);
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .footer-note {
      margin-top: 14px;
      text-align: center;
      color: var(--text-dim);
      font-size: 0.88rem;
    }

    @media (max-width: 1024px) {
      .game-layout {
        grid-template-columns: 1fr;
      }

      .sidebar {
        order: 2;
      }

      .board-column {
        order: 1;
      }
    }

    @media (max-width: 640px) {
      body {
        padding: 12px;
      }

      .board-card,
      .panel {
        padding: 14px;
      }

      .board-frame {
        padding: 10px;
      }

      .controls {
        grid-template-columns: 1fr 1fr;
      }

      .status-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .title-wrap h1 {
        font-size: 1.9rem;
      }

      .title-wrap p {
        font-size: 0.92rem;
      }

      .moves-table-wrap {
        max-height: 220px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <div class="title-wrap">
      <h1>Angel's Arcade — Checkers</h1>
      <p>Emerald and opaline draughts in the same arcade style.</p>
    </div>

    <div class="game-layout">
      <div class="board-column">
        <div class="board-card">
          <div class="board-frame">
            <div class="board-inner">
              <div id="board" class="board-grid" aria-label="Checkers board"></div>
            </div>
          </div>
          <div class="footer-note">
            Standard American checkers • forced captures • chained jumps • kings
          </div>
        </div>
      </div>

      <aside class="sidebar">
        <section class="panel">
          <h2>Controls</h2>
          <div class="controls">
            <button id="newGameBtn" class="btn">New Game</button>
            <button id="undoBtn" class="btn">Undo Move</button>
            <button id="flipBtn" class="btn">Flip Board</button>
            <button id="homeBtn" class="btn full">Go Back Home</button>
          </div>
        </section>

        <section class="panel">
          <h2>Game Status</h2>
          <div class="status-grid">
            <div class="status-row">
              <div class="status-label">Turn</div>
              <div class="status-value" id="turnValue">Light</div>
            </div>
            <div class="status-row">
              <div class="status-label">Result</div>
              <div class="status-value" id="resultValue">In progress</div>
            </div>
            <div class="status-row">
              <div class="status-label">State</div>
              <div class="status-value" id="stateValue">Select a piece to move.</div>
            </div>
          </div>
        </section>

        <section class="panel">
          <h2>Captured Pieces</h2>
          <div class="capture-wrap">
            <div class="capture-box">
              <h3>Light captured</h3>
              <div id="lightCaptured" class="capture-pieces"></div>
            </div>
            <div class="capture-box">
              <h3>Dark captured</h3>
              <div id="darkCaptured" class="capture-pieces"></div>
            </div>
          </div>
        </section>

        <section class="panel">
          <h2>Move List</h2>
          <div class="moves-table-wrap">
            <table>
              <thead>
                <tr>
                  <th style="width: 56px;">#</th>
                  <th>Light</th>
                  <th>Dark</th>
                </tr>
              </thead>
              <tbody id="moveListBody"></tbody>
            </table>
          </div>
          <div class="note">
            Moves use simple square notation. Jumps are marked with “x”, normal moves with “-”.
          </div>
        </section>
      </aside>
    </div>
  </div>

  <script>
    (() => {
      const SIZE = 8;
      const LIGHT = "light";
      const DARK = "dark";

      const boardEl = document.getElementById("board");
      const turnValueEl = document.getElementById("turnValue");
      const resultValueEl = document.getElementById("resultValue");
      const stateValueEl = document.getElementById("stateValue");
      const lightCapturedEl = document.getElementById("lightCaptured");
      const darkCapturedEl = document.getElementById("darkCaptured");
      const moveListBodyEl = document.getElementById("moveListBody");

      const newGameBtn = document.getElementById("newGameBtn");
      const undoBtn = document.getElementById("undoBtn");
      const flipBtn = document.getElementById("flipBtn");
      const homeBtn = document.getElementById("homeBtn");

      let state = null;
      let selected = null;
      let legalMovesForSelected = [];
      let flipped = false;
      let squareElements = [];
      let history = [];

      function createInitialBoard() {
        const board = Array.from({ length: SIZE }, () => Array(SIZE).fill(null));

        for (let r = 0; r < 3; r++) {
          for (let c = 0; c < SIZE; c++) {
            if (isDarkSquare(r, c)) {
              board[r][c] = { color: DARK, king: false };
            }
          }
        }

        for (let r = 5; r < 8; r++) {
          for (let c = 0; c < SIZE; c++) {
            if (isDarkSquare(r, c)) {
              board[r][c] = { color: LIGHT, king: false };
            }
          }
        }

        return board;
      }

      function createInitialState() {
        return {
          board: createInitialBoard(),
          turn: LIGHT,
          capturedLight: [],
          capturedDark: [],
          moves: [],
          result: null,
          forcedPiece: null,
          pendingChain: false,
          stateMessage: "Select a piece to move.",
          lastMoveSquares: []
        };
      }

      function cloneState(src) {
        return {
          board: src.board.map(row =>
            row.map(cell => (cell ? { color: cell.color, king: cell.king } : null))
          ),
          turn: src.turn,
          capturedLight: src.capturedLight.map(p => ({ color: p.color, king: p.king })),
          capturedDark: src.capturedDark.map(p => ({ color: p.color, king: p.king })),
          moves: src.moves.map(m => ({ ...m, path: [...m.path], captured: [...m.captured] })),
          result: src.result ? { ...src.result } : null,
          forcedPiece: src.forcedPiece ? { ...src.forcedPiece } : null,
          pendingChain: src.pendingChain,
          stateMessage: src.stateMessage,
          lastMoveSquares: src.lastMoveSquares.map(s => ({ ...s }))
        };
      }

      function isDarkSquare(r, c) {
        return (r + c) % 2 === 1;
      }

      function inBounds(r, c) {
        return r >= 0 && r < SIZE && c >= 0 && c < SIZE;
      }

      function opponent(color) {
        return color === LIGHT ? DARK : LIGHT;
      }

      function colorLabel(color) {
        return color === LIGHT ? "Light" : "Dark";
      }

      function directionsForPiece(piece) {
        if (piece.king) {
          return [
            [-1, -1], [-1, 1],
            [1, -1],  [1, 1]
          ];
        }
        return piece.color === LIGHT
          ? [[-1, -1], [-1, 1]]
          : [[1, -1], [1, 1]];
      }

      function squareToNotation(r, c) {
        const file = String.fromCharCode(97 + c);
        const rank = 8 - r;
        return file + rank;
      }

      function notationForMove(path, isCapture) {
        return path.map(sq => squareToNotation(sq.r, sq.c)).join(isCapture ? "x" : "-");
      }

      function crownIfNeeded(piece, r) {
        if (piece.king) return false;
        if (piece.color === LIGHT && r === 0) {
          piece.king = true;
          return true;
        }
        if (piece.color === DARK && r === 7) {
          piece.king = true;
          return true;
        }
        return false;
      }

      function getAllMoves(board, color, options = {}) {
        const forcedFrom = options.forcedFrom || null;
        const allMoves = [];
        let captureMoves = [];

        for (let r = 0; r < SIZE; r++) {
          for (let c = 0; c < SIZE; c++) {
            const piece = board[r][c];
            if (!piece || piece.color !== color) continue;
            if (forcedFrom && (forcedFrom.r !== r || forcedFrom.c !== c)) continue;

            const moves = getMovesForPiece(board, r, c, piece, !!forcedFrom);
            const captures = moves.filter(m => m.isCapture);
            if (captures.length) {
              captureMoves = captureMoves.concat(captures);
            }
            allMoves.push(...moves);
          }
        }

        if (captureMoves.length) {
          return captureMoves;
        }
        return forcedFrom ? [] : allMoves.filter(m => !m.isCapture);
      }

      function getMovesForPiece(board, r, c, piece, chainOnly = false) {
        const moves = [];
        const dirs = directionsForPiece(piece);

        for (const [dr, dc] of dirs) {
          const nr = r + dr;
          const nc = c + dc;
          const jr = r + dr * 2;
          const jc = c + dc * 2;

          if (inBounds(jr, jc)) {
            const mid = board[nr][nc];
            const landing = board[jr][jc];
            if (mid && mid.color !== piece.color && !landing) {
              moves.push({
                from: { r, c },
                to: { r: jr, c: jc },
                isCapture: true,
                captured: [{ r: nr, c: nc }],
                path: [{ r, c }, { r: jr, c: jc }]
              });
            }
          }
        }

        if (chainOnly) {
          return moves.filter(m => m.isCapture);
        }

        if (moves.some(m => m.isCapture)) {
          return moves;
        }

        for (const [dr, dc] of dirs) {
          const nr = r + dr;
          const nc = c + dc;
          if (inBounds(nr, nc) && !board[nr][nc]) {
            moves.push({
              from: { r, c },
              to: { r: nr, c: nc },
              isCapture: false,
              captured: [],
              path: [{ r, c }, { r: nr, c: nc }]
            });
          }
        }

        return moves;
      }

      function hasAnyMoves(board, color) {
        return getAllMoves(board, color).length > 0;
      }

      function countPieces(board, color) {
        let total = 0;
        for (let r = 0; r < SIZE; r++) {
          for (let c = 0; c < SIZE; c++) {
            if (board[r][c] && board[r][c].color === color) total++;
          }
        }
        return total;
      }

      function buildPieceSVG(piece) {
        const isLight = piece.color === LIGHT;
        const baseTop = isLight ? "#fbf9ff" : "#263d37";
        const baseMid = isLight ? "#e8e1f4" : "#15241f";
        const baseBot = isLight ? "#c9bfd9" : "#0c1211";
        const rim = isLight ? "#ffffff" : "#4d6960";
        const ring = isLight ? "#a78cff" : "#88d6b2";
        const shadow = isLight ? "rgba(86,72,118,0.28)" : "rgba(0,0,0,0.38)";

        return `
          <svg class="piece-svg" viewBox="0 0 100 100" aria-hidden="true">
            <defs>
              <radialGradient id="g-${piece.color}-${piece.king ? "k" : "m"}-a" cx="35%" cy="28%" r="70%">
                <stop offset="0%" stop-color="${baseTop}"></stop>
                <stop offset="58%" stop-color="${baseMid}"></stop>
                <stop offset="100%" stop-color="${baseBot}"></stop>
              </radialGradient>
            </defs>
            <ellipse cx="50" cy="82" rx="28" ry="8" fill="${shadow}"></ellipse>
            <circle cx="50" cy="52" r="28" fill="url(#g-${piece.color}-${piece.king ? "k" : "m"}-a)"></circle>
            <ellipse cx="50" cy="54" rx="25" ry="22" fill="none" stroke="${rim}" stroke-opacity="0.35" stroke-width="2"></ellipse>
            <ellipse cx="42" cy="39" rx="16" ry="8" fill="rgba(255,255,255,0.20)"></ellipse>
            <circle cx="50" cy="52" r="28" fill="none" stroke="rgba(0,0,0,0.22)" stroke-width="2.2"></circle>
            ${
              piece.king
                ? `
                  <circle cx="50" cy="52" r="14" fill="none" stroke="${ring}" stroke-width="4.2"></circle>
                  <path d="M35 48 L42 38 L50 46 L58 38 L65 48 L65 58 L35 58 Z"
                        fill="${ring}" fill-opacity="0.92" stroke="rgba(0,0,0,0.24)" stroke-width="1.4"></path>
                  <circle cx="42" cy="39" r="2.2" fill="${ring}"></circle>
                  <circle cx="50" cy="46" r="2.2" fill="${ring}"></circle>
                  <circle cx="58" cy="39" r="2.2" fill="${ring}"></circle>
                `
                : ""
            }
          </svg>
        `;
      }

      function createBoardSquares() {
        boardEl.innerHTML = "";
        squareElements = [];

        for (let vr = 0; vr < SIZE; vr++) {
          const row = [];
          for (let vc = 0; vc < SIZE; vc++) {
            const sq = document.createElement("button");
            sq.type = "button";
            sq.className = "square";
            sq.setAttribute("aria-label", "Board square");
            sq.addEventListener("click", () => handleSquareClick(vr, vc));
            boardEl.appendChild(sq);
            row.push(sq);
          }
          squareElements.push(row);
        }
      }

      function viewToBoard(vr, vc) {
        if (!flipped) return { r: vr, c: vc };
        return { r: SIZE - 1 - vr, c: SIZE - 1 - vc };
      }

      function boardToView(r, c) {
        if (!flipped) return { vr: r, vc: c };
        return { vr: SIZE - 1 - r, vc: SIZE - 1 - c };
      }

      function renderBoard() {
        const mandatoryMoves = getAllMoves(
          state.board,
          state.turn,
          state.pendingChain && state.forcedPiece ? { forcedFrom: state.forcedPiece } : {}
        );

        const mandatorySources = new Set(
          mandatoryMoves.map(m => `${m.from.r},${m.from.c}`)
        );

        for (let vr = 0; vr < SIZE; vr++) {
          for (let vc = 0; vc < SIZE; vc++) {
            const sqEl = squareElements[vr][vc];
            const { r, c } = viewToBoard(vr, vc);
            const piece = state.board[r][c];
            const dark = isDarkSquare(r, c);

            sqEl.className = `square ${dark ? "dark" : "light"}`;
            sqEl.innerHTML = "";

            const isSelected = selected && selected.r === r && selected.c === c;
            const isLegal = legalMovesForSelected.some(m => m.to.r === r && m.to.c === c);
            const isCaptureTarget = legalMovesForSelected.some(m => m.to.r === r && m.to.c === c && m.isCapture);
            const isMustPiece = mandatorySources.has(`${r},${c}`);
            const isLastMoveSquare = state.lastMoveSquares.some(s => s.r === r && s.c === c);

            if (isSelected) sqEl.classList.add("selected");
            if (isLegal) sqEl.classList.add("legal");
            if (isCaptureTarget) sqEl.classList.add("capture-target");
            if (isMustPiece && !state.result) sqEl.classList.add("must-piece");
            if (isLastMoveSquare) sqEl.classList.add("last-move");

            if (piece) {
              const pieceWrap = document.createElement("div");
              pieceWrap.className = "piece";
              pieceWrap.innerHTML = buildPieceSVG(piece);
              sqEl.appendChild(pieceWrap);
            }

            const coords = document.createElement("div");
            coords.className = "coords";

            const showRank = (!flipped && c === 0) || (flipped && c === 7);
            const showFile = (!flipped && r === 7) || (flipped && r === 0);

            if (showRank) {
              const rank = document.createElement("div");
              rank.className = "coord-rank";
              rank.textContent = String(8 - r);
              coords.appendChild(rank);
            }

            if (showFile) {
              const file = document.createElement("div");
              file.className = "coord-file";
              file.textContent = String.fromCharCode(97 + c);
              coords.appendChild(file);
            }

            if (showRank || showFile) {
              sqEl.appendChild(coords);
            }
          }
        }
      }

      function renderCaptured() {
        lightCapturedEl.innerHTML = "";
        darkCapturedEl.innerHTML = "";

        for (const piece of state.capturedLight) {
          const el = document.createElement("div");
          el.className = "capture-piece";
          el.innerHTML = buildPieceSVG(piece);
          lightCapturedEl.appendChild(el);
        }

        for (const piece of state.capturedDark) {
          const el = document.createElement("div");
          el.className = "capture-piece";
          el.innerHTML = buildPieceSVG(piece);
          darkCapturedEl.appendChild(el);
        }
      }

      function renderMoves() {
        moveListBodyEl.innerHTML = "";
        const rows = [];

        for (let i = 0; i < state.moves.length; i += 2) {
          rows.push({
            number: rows.length + 1,
            light: state.moves[i] ? state.moves[i].notation : "",
            dark: state.moves[i + 1] ? state.moves[i + 1].notation : ""
          });
        }

        if (!rows.length) {
          const tr = document.createElement("tr");
          tr.innerHTML = `<td colspan="3" style="color: var(--text-dim);">No moves yet.</td>`;
          moveListBodyEl.appendChild(tr);
          return;
        }

        for (const row of rows) {
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td>${row.number}.</td>
            <td>${escapeHTML(row.light)}</td>
            <td>${escapeHTML(row.dark)}</td>
          `;
          moveListBodyEl.appendChild(tr);
        }
      }

      function renderStatus() {
        turnValueEl.textContent = colorLabel(state.turn);
        resultValueEl.textContent = state.result ? state.result.text : "In progress";
        stateValueEl.textContent = state.stateMessage;
      }

      function renderAll() {
        renderBoard();
        renderCaptured();
        renderMoves();
        renderStatus();
        undoBtn.disabled = history.length === 0;
      }

      function escapeHTML(str) {
        return String(str)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;");
      }

      function clearSelection() {
        selected = null;
        legalMovesForSelected = [];
      }

      function setSelection(r, c) {
        if (state.result) return;

        const piece = state.board[r][c];
        if (!piece || piece.color !== state.turn) {
          clearSelection();
          return;
        }

        if (state.pendingChain && state.forcedPiece) {
          if (state.forcedPiece.r !== r || state.forcedPiece.c !== c) return;
          legalMovesForSelected = getAllMoves(state.board, state.turn, { forcedFrom: { r, c } });
        } else {
          const allMoves = getAllMoves(state.board, state.turn);
          legalMovesForSelected = allMoves.filter(m => m.from.r === r && m.from.c === c);
        }

        if (!legalMovesForSelected.length) {
          clearSelection();
          return;
        }

        selected = { r, c };
      }

      function handleSquareClick(vr, vc) {
        const { r, c } = viewToBoard(vr, vc);
        if (state.result) return;

        const clickedPiece = state.board[r][c];

        if (selected) {
          const chosenMove = legalMovesForSelected.find(m => m.to.r === r && m.to.c === c);
          if (chosenMove) {
            applyMove(chosenMove);
            return;
          }
        }

        if (clickedPiece && clickedPiece.color === state.turn) {
          if (selected && selected.r === r && selected.c === c) {
            clearSelection();
          } else {
            setSelection(r, c);
          }
          renderAll();
          return;
        }

        clearSelection();
        renderAll();
      }

      function pushHistory() {
        history.push(cloneState(state));
      }

      function applyMove(move) {
        pushHistory();

        const board = state.board;
        const piece = board[move.from.r][move.from.c];
        board[move.from.r][move.from.c] = null;
        board[move.to.r][move.to.c] = piece;

        const capturedPieces = [];
        for (const cap of move.captured) {
          const victim = board[cap.r][cap.c];
          if (victim) {
            capturedPieces.push({ ...victim });
            if (victim.color === LIGHT) {
              state.capturedLight.push({ ...victim });
            } else {
              state.capturedDark.push({ ...victim });
            }
            board[cap.r][cap.c] = null;
          }
        }

        const becameKing = crownIfNeeded(piece, move.to.r);

        state.lastMoveSquares = move.path.map(p => ({ ...p }));

        const continuationMoves = move.isCapture
          ? getAllMoves(board, piece.color, { forcedFrom: { r: move.to.r, c: move.to.c } })
          : [];

        let notation = notationForMove(move.path, move.isCapture);
        if (becameKing) notation += "K";

        if (move.isCapture && continuationMoves.length) {
          state.pendingChain = true;
          state.forcedPiece = { r: move.to.r, c: move.to.c };
          state.stateMessage = `${colorLabel(piece.color)} must continue jumping.`;
          clearSelection();
          setSelection(move.to.r, move.to.c);

          state.moves.push({
            color: piece.color,
            notation,
            path: move.path.map(p => ({ ...p })),
            captured: move.captured.map(c => ({ ...c }))
          });

          const last = state.moves[state.moves.length - 1];
          last.notation += "…";

          renderAll();
          return;
        }

        state.pendingChain = false;
        state.forcedPiece = null;
        clearSelection();

        state.moves.push({
          color: piece.color,
          notation,
          path: move.path.map(p => ({ ...p })),
          captured: move.captured.map(c => ({ ...c }))
        });

        state.turn = opponent(state.turn);
        evaluatePosition();
        renderAll();
      }

      function evaluatePosition() {
        const lightCount = countPieces(state.board, LIGHT);
        const darkCount = countPieces(state.board, DARK);

        if (lightCount === 0) {
          state.result = { winner: DARK, text: "Dark wins — light has no pieces." };
          state.stateMessage = "Game over.";
          return;
        }

        if (darkCount === 0) {
          state.result = { winner: LIGHT, text: "Light wins — dark has no pieces." };
          state.stateMessage = "Game over.";
          return;
        }

        const legal = getAllMoves(state.board, state.turn);
        if (!legal.length) {
          state.result = {
            winner: opponent(state.turn),
            text: `${colorLabel(opponent(state.turn))} wins — ${colorLabel(state.turn).toLowerCase()} has no legal moves.`
          };
          state.stateMessage = "No legal moves remain.";
          return;
        }

        const captureExists = legal.some(m => m.isCapture);
        state.result = null;
        state.stateMessage = captureExists
          ? `${colorLabel(state.turn)} to move — capture is required.`
          : `${colorLabel(state.turn)} to move.`;
      }

      function undoMove() {
        if (!history.length) return;
        state = history.pop();
        clearSelection();
        renderAll();
      }

      function newGame() {
        state = createInitialState();
        history = [];
        clearSelection();
        evaluatePosition();
        renderAll();
      }

      function flipBoard() {
        flipped = !flipped;
        renderBoard();
      }

      newGameBtn.addEventListener("click", newGame);
      undoBtn.addEventListener("click", undoMove);
      flipBtn.addEventListener("click", flipBoard);
      homeBtn.addEventListener("click", () => {
        window.location.href = "../../index.html";
      });

      createBoardSquares();
      newGame();
    })();
  </script>
</body>
</html>
